# Copy to .env (gitignored) and edit locally. No real secrets committed.
# Names and defaults mirror IMPLEMENTATION_PLAN.md §6 and PRD §11.

# --- backend ---
DATABASE_URL=postgresql://postgres:postgres@db:5432/ticket_db
MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english
HF_HOME=/opt/hf-cache
TRANSFORMERS_OFFLINE=1
# CORS_ALLOWED_ORIGINS=   # empty = disabled (reverse proxy is the default)
# LOG_LEVEL=info

# --- frontend (Vite: baked at build time, not runtime) ---
VITE_API_BASE_URL=/api

# --- postgres (used by the db service in docker-compose.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ticket_db
